{
  "name": "chrome-bridge-mcp",
  "version": "1.0.0",
  "description": "MCP server that bridges Claude Code to a Chrome extension via WebSocket",
  "private": true,
  "type": "module",
  "workspaces": [
    "mcp-server",
    "extension"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "prestart": "npm run build:mcp",
    "start": "npm run start --workspace mcp-server",
    "dev": "npm run dev --workspace mcp-server",
    "build:mcp": "npm run build --workspace mcp-server",
    "build:extension": "npm run build --workspace extension"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
